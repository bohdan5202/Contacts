<Window x:Class="Contacts.Views.ContactDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Contact" Height="460" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F7F9FC">

    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Margin" Value="0,4,0,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderBrush" Value="#BCC8D4"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#4A5568"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="18,7"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Fields -->
        <StackPanel Grid.Row="0">
            <Label Content="First Name"/>
            <TextBox x:Name="TxtFirstName"/>

            <Label Content="Last Name"/>
            <TextBox x:Name="TxtLastName"/>

            <Label Content="Email"/>
            <TextBox x:Name="TxtEmail"/>

            <Label Content="Phone"/>
            <TextBox x:Name="TxtPhone"/>

            <Label Content="City"/>
            <TextBox x:Name="TxtCity"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <Label Content="Age"/>
                    <TextBox x:Name="TxtAge"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <Label Content="Group"/>
                    <ComboBox x:Name="CmbGroup" Padding="6,4" Margin="0,4,0,8" FontSize="13">
                        <ComboBoxItem>Family</ComboBoxItem>
                        <ComboBoxItem>Friend</ComboBoxItem>
                        <ComboBoxItem>Work</ComboBoxItem>
                    </ComboBox>
                </StackPanel>
            </Grid>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button x:Name="BtnCancel" Content="Cancel" Click="BtnCancel_Click"
                    Background="#E2E8F0" Foreground="#4A5568" Margin="0,0,10,0"/>
            <Button x:Name="BtnSave"   Content="Save"   Click="BtnSave_Click"
                    Background="#4F80C8" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>
